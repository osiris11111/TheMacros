{
  "entities": {
    "User": {
      "title": "User",
      "description": "A user profile in the application.",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "name": { "type": "string" },
        "role": { "type": "string", "enum": ["customer", "admin"] },
        "createdAt": { "type": "string", "format": "date-time" },
        "deliveryInfo": {
          "type": "object",
          "properties": {
            "name": { "type": "string" },
            "phone": { "type": "string" },
            "email": { "type": "string" },
            "address": { "type": "string" }
          }
        }
      },
      "required": ["uid", "email", "name", "role"]
    },
    "Order": {
      "title": "Order",
      "description": "A customer order.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string", "description": "Optional user ID for authenticated users." },
        "guestId": { "type": "string", "description": "Optional guest ID for unauthenticated users." },
        "cancellable": { "type": "boolean" },
        "items": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "id": { "type": "number" },
              "title": { "type": "string" },
              "price": { "type": "string" },
              "qty": { "type": "number" },
              "img": { "type": "string" }
            }
          }
        },
        "total": { "type": "string" },
        "promoCode": { "type": "string" },
        "discountAmount": { "type": "string" },
        "status": { "type": "string", "enum": ["pending", "preparing", "delivering", "completed", "cancelled"] },
        "deliveryDetails": {
          "type": "object",
          "properties": {
            "name": { "type": "string" },
            "phone": { "type": "string" },
            "email": { "type": "string" },
            "address": { "type": "string" },
            "locationLink": { "type": "string" },
            "paymentMethod": { "type": "string" }
          }
        },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "items", "total", "status", "deliveryDetails", "createdAt"]
    },
    "Review": {
      "title": "Review",
      "description": "A review for an order or menu item.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "userName": { "type": "string" },
        "rating": { "type": "number" },
        "comment": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "userId", "userName", "rating", "createdAt"]
    },
    "Promo": {
      "title": "Promo",
      "description": "A promotional discount code.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "code": { "type": "string" },
        "discountType": { "type": "string", "enum": ["percentage", "fixed"] },
        "discountValue": { "type": "number" },
        "maxUsesOverall": { "type": "number" },
        "maxUsesPerUser": { "type": "number" },
        "currentUses": { "type": "number" },
        "usedBy": { "type": "object" }
      },
      "required": ["id", "code", "discountType", "discountValue", "maxUsesOverall", "maxUsesPerUser", "currentUses"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": { "$ref": "#/entities/User" },
      "description": "Stores user profiles."
    },
    "/orders/{orderId}": {
      "schema": { "$ref": "#/entities/Order" },
      "description": "Stores customer orders."
    },
    "/reviews/{reviewId}": {
      "schema": { "$ref": "#/entities/Review" },
      "description": "Stores customer reviews."
    },
    "/promos/{promoId}": {
      "schema": { "$ref": "#/entities/Promo" },
      "description": "Stores promotional codes."
    }
  }
}
